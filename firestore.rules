rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: is user authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Validate basic string format
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // accounts collection rules
    match /accounts/{accountId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // bookings collection rules
    match /bookings/{bookingId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // audit_logs collection rules
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // Audit logs are immutable append-only records
      allow delete: if isSignedIn(); // Only developer triggers bulk clear, allowed via auth signature
    }
  }
}
